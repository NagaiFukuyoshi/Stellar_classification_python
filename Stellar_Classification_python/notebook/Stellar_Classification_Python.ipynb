       "QSO       1.719676\n",
       "GALAXY    0.421596\n",
       "STAR     -0.000115\n",
       "Name: redshift, dtype: float64"
      ]
     },
     "execution_count": 30,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
