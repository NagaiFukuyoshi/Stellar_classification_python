   "source": [
    "def graficar (datos,titulo,xlabel,ylabel,kind='bar',color='blue',edgecolor='black',rotation=45,linestyle='--',alpha=0.7,):\n",
    "    \n",
    "    plt.figure(figsize=(12,8))\n",
    "    datos.plot(kind=kind, color=color, edgecolor=edgecolor)\n",
    "    plt.title(titulo)\n",
    "    plt.xlabel(xlabel)\n",
    "    plt.ylabel(ylabel)\n",
    "    plt.xticks(rotation=rotation, ha='center')\n",
    "    plt.grid(axis='y', linestyle=linestyle, alpha=alpha)\n",
    "    plt.axhline(y=0, color='black', linewidth=0.8, linestyle='-')\n",
    "    plt.savefig(f'outputs\\graficos\\{titulo.replace(\" \", \"_\")}.png', dpi=300, bbox_inches='tight')\n",
    "    plt.show()"
   ]
  },
